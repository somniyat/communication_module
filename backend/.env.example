NODE_ENV=development
PORT=4000

MONGO_URI=mongodb://localhost:27017/communication_module

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Default scheduler tick (ms). Overridable per customer.
JOB_INTERVAL_MS=1000
JOB_ENABLED=true

# Outbound channel defaults (per-customer settings override these where applicable)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Set to false to skip TLS cert validation (dev / self-signed / hostname mismatch).
SMTP_REJECT_UNAUTHORIZED=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# In production, also serves the React build from backend/client/
SERVE_CLIENT=false
